<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="12dp"
    android:layout_marginEnd="10dp"
    android:minWidth="170dp">

    <TextView
        android:id="@+id/tvJudulRiwayatLaporan"
        android:text="Laporan 09 Jul 2026"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:maxLines="2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvTanggalRiwayatLaporan"
        android:text="09 Jul 2026, 10:23"
        android:textSize="10sp"
        android:textColor="#999999"
        android:layout_marginTop="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvTotalResiRiwayatLaporan"
        android:text="142 resi"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/banner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvTotalPendapatanRiwayatLaporan"
        android:text="Rp 5.400.000"
        android:textSize="11sp"
        android:textColor="#555555"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>