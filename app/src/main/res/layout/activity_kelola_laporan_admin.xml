<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/banner"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FFFFFF"/>

        <TextView
            android:text="Laporan Pengiriman"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerInParent="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- ===================== SECTION 1: BUAT LAPORAN ===================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:layout_margin="12dp"
                android:padding="16dp">

                <TextView
                    android:text="Buat Laporan"
                    android:textColor="@color/banner"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Jenis Laporan -->
                <TextView
                    android:text="Jenis Laporan"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerJenisLaporan"
                    android:entries="@array/jenis_laporan_array"
                    android:background="@android:drawable/btn_dropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- Periode -->
                <TextView
                    android:text="Periode"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etPeriodeAwal"
                        android:hint="Dari Tanggal"
                        android:focusable="false"
                        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etPeriodeAkhir"
                        android:hint="Sampai Tanggal"
                        android:focusable="false"
                        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <!-- Tipe Data -->
                <TextView
                    android:text="Tipe Data"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerTipeData"
                    android:entries="@array/tipe_data_array"
                    android:background="@android:drawable/btn_dropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- Tombol Generate -->
                <Button
                    android:id="@+id/btnGenerateLaporan"
                    android:text="Generate Laporan"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/banner"
                    android:layout_marginTop="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- ===================== SECTION 2: RINGKASAN ===================== -->
            <LinearLayout
                android:id="@+id/layoutRingkasan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="4dp"
                android:visibility="visible">

                <!-- Total Resi -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tvTotalResi"
                        android:text="0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/banner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Total Resi"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <!-- Terkirim -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/tvTerkirim"
                        android:text="0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#388E3C"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Terkirim"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <!-- Pendapatan -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.3"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:id="@+id/tvTotalPendapatan"
                        android:text="0"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Pendapatan"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ===================== SECTION 3: FILTER HASIL ===================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:layout_margin="12dp"
                android:padding="16dp">

                <TextView
                    android:text="Filter Hasil"
                    android:textColor="@color/banner"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etCariResi"
                    android:hint="Cari No. Resi / Nama"
                    android:inputType="text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="Status"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <Spinner
                            android:id="@+id/spinnerStatus"
                            android:entries="@array/status_laporan_array"
                            android:background="@android:drawable/btn_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="Kota Tujuan"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <Spinner
                            android:id="@+id/spinnerKota"
                            android:entries="@array/kota_filter_array"
                            android:background="@android:drawable/btn_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ===================== SECTION 4: LIST HASIL ===================== -->
            <TextView
                android:text="Riwayat Pengiriman"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerLaporan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- ===================== RIWAYAT LAPORAN (tersimpan) ===================== -->
            <TextView
                android:text="Riwayat Laporan"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRiwayatLaporan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvKosongRiwayatLaporan"
                android:text="Belum ada laporan yang di-generate"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


        </LinearLayout>

    </ScrollView>

</LinearLayout>