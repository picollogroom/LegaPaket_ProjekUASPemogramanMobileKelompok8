<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/tvStatusRiwayatItem"
        android:text="Resi Dibuat"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/banner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvWaktuRiwayatItem"
        android:text="09 Jul 2026, 10:00"
        android:textSize="11sp"
        android:textColor="#999999"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvKeteranganRiwayatItem"
        android:text="Paket terdaftar di sistem"
        android:textSize="12sp"
        android:textColor="#555555"
        android:layout_marginTop="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>